{
  "expo": {
    "name": "SecondSet Signer",
    "slug": "secondset-signer",
    "owner": "nickdoescode1717",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.secondset.signer",
      "infoPlist": {
        "NSFaceIDUsageDescription": "SecondSet Signer requires Face ID to approve transactions.",
        "NSCameraUsageDescription": "Camera is needed to scan QR codes for wallet setup.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.secondset.signer",
      "permissions": [
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow SecondSet Signer to use Face ID."
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SecondSet Signer to access camera for scanning QR codes."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#2D9D92"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1595f7b9-732e-4f84-9372-a878d73548b9"
      }
    }
  }
}
