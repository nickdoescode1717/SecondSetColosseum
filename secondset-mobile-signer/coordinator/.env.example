# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/secondset_coordinator

# Server Configuration
# Coordinator runs on port 3000 (Web App uses 3002)
PORT=3000
NODE_ENV=development

# JWT Secret for WebSocket Authentication
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-in-production

# Web App Webhook Configuration
# URL where the coordinator will send ceremony completion webhooks
# Web App runs on port 3002
WEBAPP_WEBHOOK_URL=http://localhost:3002/api/coordinator/webhook
WEB_APP_URL=http://localhost:3002

# Secret for signing webhook payloads (HMAC-SHA256)
# Generate with: openssl rand -hex 32
# Web app uses this same secret to verify webhook authenticity
COORDINATOR_WEBHOOK_SECRET=dev-webhook-secret-change-in-production
